<svg width="48" height="48" viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <linearGradient id="bar1" x1="0" y1="1" x2="0" y2="0">
      <stop offset="0%" stop-color="#1D4ED8"/>
      <stop offset="100%" stop-color="#7DD3FC"/>
    </linearGradient>
    <linearGradient id="bar2" x1="0" y1="1" x2="0" y2="0">
      <stop offset="0%" stop-color="#2563EB"/>
      <stop offset="100%" stop-color="#BAE6FD"/>
    </linearGradient>
    <linearGradient id="ringG" x1="0" y1="0" x2="1" y2="1">
      <stop offset="0%" stop-color="#60D0FF"/>
      <stop offset="100%" stop-color="#1E6FA8" stop-opacity="0.4"/>
    </linearGradient>
    <filter id="gR">
      <feGaussianBlur stdDeviation="1.5" result="blur"/>
      <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
    </filter>
    <filter id="gB">
      <feGaussianBlur stdDeviation="1" result="blur"/>
      <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
    </filter>
  </defs>

  <!-- background circle -->
  <circle cx="24" cy="24" r="22" fill="#060F1E" stroke="url(#ringG)" stroke-width="2"/>

  <!-- comet tail: cyan -> red, sweeping to dot at ~30deg (~28,10) -->
  <path d="M 10 17 A 22 22 0 0 1 15 12" fill="none" stroke="#38BDF8" stroke-width="1.2" stroke-linecap="butt" opacity="0.08"/>
  <path d="M 15 12 A 22 22 0 0 1 20 9.5" fill="none" stroke="#818CF8" stroke-width="1.8" stroke-linecap="butt" opacity="0.18"/>
  <path d="M 20 9.5 A 22 22 0 0 1 24 9" fill="none" stroke="#A855F7" stroke-width="2.5" stroke-linecap="butt" opacity="0.32"/>
  <path d="M 24 9 A 22 22 0 0 1 27 9.5" fill="none" stroke="#DC2626" stroke-width="3.2" stroke-linecap="butt" opacity="0.55"/>
  <path d="M 27 9.5 A 22 22 0 0 1 29.5 11" fill="none" stroke="#CC0000" stroke-width="4" stroke-linecap="round" opacity="0.85"/>

  <!-- red dot with glow rings -->
  <circle cx="29.5" cy="11" r="5" fill="#8B0000" opacity="0.2"/>
  <circle cx="29.5" cy="11" r="3.5" fill="#CC0000" opacity="0.4"/>
  <circle cx="29.5" cy="11" r="2.5" fill="#FF2020" filter="url(#gR)"/>

  <!-- bars -->
  <rect x="13" y="28" width="5" height="8" rx="1.5" fill="url(#bar1)" opacity="0.75"/>
  <rect x="21" y="22" width="5" height="14" rx="1.5" fill="url(#bar2)" opacity="0.9" filter="url(#gB)"/>
  <rect x="29" y="17" width="5" height="19" rx="1.5" fill="url(#bar2)" filter="url(#gB)"/>

  <!-- baseline -->
  <line x1="11" y1="37" x2="37" y2="37" stroke="#38BDF8" stroke-width="1.5" stroke-linecap="round" opacity="0.5"/>
</svg>
